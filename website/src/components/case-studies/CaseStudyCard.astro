---
import {Image} from 'astro:assets';
import {Icon} from 'astro-icon/components';
import type {ImageMetadata} from 'astro';

export interface Props {
  company: string;
  industry: string;
  useCase: string;
  quote: string;
  logo: ImageMetadata;
  logoLight?: ImageMetadata;
  logoDark?: ImageMetadata;
  person: {
    name: string;
    role: string;
    image: ImageMetadata;
  };
  slug: string;
}

const {
  company,
  industry,
  useCase,
  quote,
  logo,
  logoLight,
  logoDark,
  person,
  slug,
} = Astro.props;

const useThemedLogo = logoLight && logoDark;
---

<div
  class="bg-white dark:bg-gray-900 rounded-xl p-6 md:p-8 shadow-md max-w-6xl mx-auto"
  data-slug={slug}>
  <!-- Main Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main Content (2/3) -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Header with Logo and Info -->
      <div class="flex flex-col md:flex-row gap-6 md:gap-12 mb-8">
        {
          useThemedLogo ? (
            <>
              <Image
                src={logoLight}
                alt={`${company} Logo`}
                class="h-24 w-auto rounded-xl object-contain dark:hidden"
                width={200}
                height={96}
              />
              <Image
                src={logoDark}
                alt={`${company} Logo`}
                class="h-24 w-auto rounded-xl object-contain hidden dark:block"
                width={200}
                height={96}
              />
            </>
          ) : (
            <Image
              src={logo}
              alt={`${company} Logo`}
              class="h-24 w-auto rounded-xl object-contain"
              width={200}
              height={96}
            />
          )
        }
        <div class="flex flex-col gap-2">
          <div class="text-center md:text-left">
            <div
              class="text-sm font-semibold text-[#00b5eb] uppercase tracking-wide">
              Industry:
            </div>
            <div class="text-base font-medium text-gray-900 dark:text-white">
              {industry}
            </div>
          </div>
          <div class="text-center md:text-left">
            <div
              class="text-sm font-semibold text-[#00b5eb] uppercase tracking-wide">
              Use Case:
            </div>
            <div class="text-base font-medium text-gray-900 dark:text-white">
              {useCase}
            </div>
          </div>
        </div>
      </div>

      <!-- Case study narrative (rendered from the customer markdown body) -->
      <div
        class="text-base leading-relaxed text-gray-700 dark:text-gray-300 [&>h2:first-child]:mt-0 [&_h2]:text-lg [&_h2]:font-semibold [&_h2]:text-[#00b5eb] [&_h2]:uppercase [&_h2]:tracking-wide [&_h2]:mt-8 [&_h2]:mb-3 [&_p]:mb-4 [&_ul]:list-disc [&_ul]:list-inside [&_ul]:space-y-1 [&_ul]:mb-4 [&_a]:text-[#00b5eb] [&_a]:underline">
        <slot />
      </div>
    </div>

    <!-- Sidebar (1/3) -->
    <div class="lg:col-span-1">
      <div
        class="bg-gray-50 dark:bg-gray-800 rounded-xl p-6 sticky top-24 space-y-6">
        <!-- Quote -->
        <blockquote
          class="text-base md:text-lg leading-relaxed italic font-medium text-gray-700 dark:text-gray-300 mb-6">
          "{quote}"
        </blockquote>

        <!-- Person Info -->
        <div
          class="flex items-center gap-4 pb-6 border-b border-gray-200 dark:border-gray-700">
          <Image
            src={person.image}
            alt={person.name}
            class="w-14 h-14 md:w-16 md:h-16 rounded-full object-cover flex-shrink-0"
            width={64}
            height={64}
          />
          <div>
            <div class="font-bold text-gray-900 dark:text-white">
              {person.name}
            </div>
            <div class="text-sm text-gray-600 dark:text-gray-400">
              {person.role}, {company}
            </div>
          </div>
        </div>

        <!-- Back to Case Studies Link -->
        <a
          href="/case-studies/"
          class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-gradient-to-br from-[#00b5eb] to-[#63c5e3] text-white font-medium text-sm hover:shadow-lg transition-all duration-300 hover:scale-105 w-full justify-center">
          <Icon name="lucide:arrow-left" class="w-4 h-4" />
          All case studies
        </a>
      </div>
    </div>
  </div>
</div>
