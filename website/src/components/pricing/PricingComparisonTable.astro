---

<section class="py-8 md:py-16">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="mt-16 mx-auto">
      <h2 class="text-center mb-8 text-3xl font-bold">Compare Features</h2>
      <div
        class="overflow-x-auto bg-white dark:bg-gray-900 rounded-xl shadow-md">
        <table class="w-full border-collapse table-fixed">
          <colgroup>
            <col style="width: 24%;" />
            <col style="width: 19%;" />
            <col style="width: 19%;" />
            <col style="width: 19%;" />
            <col style="width: 19%;" />
          </colgroup>
          <thead>
            <tr>
              <th
                class="bg-white dark:bg-gray-900 font-semibold text-center p-5 border-b border-gray-200 dark:border-gray-700 text-base">
              </th>
              <th
                class="bg-white dark:bg-gray-900 font-semibold text-center p-5 border-b border-gray-200 dark:border-gray-700 text-base relative">
                Community (Open Source)
                <div
                  class="absolute bottom-0 left-[15%] right-[15%] h-[3px] rounded-full bg-gray-500">
                </div>
              </th>
              <th
                class="bg-white dark:bg-gray-900 font-semibold text-center p-5 border-b border-gray-200 dark:border-gray-700 text-base relative">
                Pro
                <div
                  class="absolute bottom-0 left-[15%] right-[15%] h-[3px] rounded-full bg-[#0ea5e9]">
                </div>
              </th>
              <th
                class="bg-white dark:bg-gray-900 font-semibold text-center p-5 border-b border-gray-200 dark:border-gray-700 text-base relative">
                Business
                <div
                  class="absolute bottom-0 left-[15%] right-[15%] h-[3px] rounded-full bg-[#8b5cf6]">
                </div>
              </th>
              <th
                class="bg-white dark:bg-gray-900 font-semibold text-center p-5 border-b border-gray-200 dark:border-gray-700 text-base relative">
                Enterprise
                <div
                  class="absolute bottom-0 left-[15%] right-[15%] h-[3px] rounded-full bg-[#10b981]">
                </div>
              </th>
            </tr>
          </thead>
          <tbody>
            {
              sections.map(section => (
                <>
                  <tr class="bg-gray-100 dark:bg-gray-800/30 border-t-2 border-b-2 border-gray-300 dark:border-gray-700">
                    <td
                      colspan="5"
                      class="font-bold text-left p-4 text-gray-900 dark:text-gray-200 uppercase tracking-wider text-sm">
                      {section.title}
                    </td>
                  </tr>
                  {section.rows.map(row => (
                    <tr>
                      <td
                        class={`p-3.5 text-left font-medium text-sm border-b border-gray-100 dark:border-gray-800${
                          row.indent
                            ? ' pl-7 text-gray-500 dark:text-gray-400'
                            : ''
                        }`}>
                        {row.label}
                      </td>
                      <td class={cellClass(row.community)}>{row.community}</td>
                      <td class={cellClass(row.pro)}>{row.pro}</td>
                      <td class={cellClass(row.business)}>{row.business}</td>
                      <td class={cellClass(row.enterprise)}>
                        {row.enterprise}
                      </td>
                    </tr>
                  ))}
                </>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<style>
  /* Mobile responsive adjustments */
  @media (max-width: 768px) {
    th:first-child,
    td:first-child {
      position: sticky;
      left: 0;
      background-color: white;
      z-index: 1;
      box-shadow: 2px 0 5px rgba(0, 0, 0, 0.1);
    }

    :global(.dark) th:first-child,
    :global(.dark) td:first-child {
      background-color: rgb(17, 24, 39);
    }

    tr:where(.bg-gray-100) td:first-child {
      background-color: rgb(243, 244, 246) !important;
    }

    :global(.dark) tr:where(.bg-gray-800\\/30) td:first-child {
      background-color: rgba(31, 41, 55, 0.3) !important;
    }
  }

  tr:not(:where(.bg-gray-100, .dark\\:bg-gray-800\\/30)):hover {
    background-color: rgba(0, 0, 0, 0.01);
  }

  :global(.dark) tr:not(:where(.bg-gray-100, .dark\\:bg-gray-800\\/30)):hover {
    background-color: rgba(255, 255, 255, 0.03);
  }
</style>
