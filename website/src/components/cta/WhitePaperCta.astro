---
interface Props {
  embedded?: boolean;
}

const {embedded = false} = Astro.props;

const Wrapper = embedded ? 'aside' : 'section';
const Heading = embedded ? 'h3' : 'h2';

const wrapperClass = embedded
  ? 'my-16 not-prose'
  : 'pt-4 pb-8 md:pt-8 md:pb-16 lg:pt-12 lg:pb-24 bg-white dark:bg-gray-900';
const containerClass = embedded ? '' : 'container mx-auto px-4 max-w-5xl';
const cardClass = embedded
  ? 'bg-gradient-to-br from-accent-600 to-accent-950 rounded-xl p-6 md:p-8 shadow-lg text-center'
  : 'bg-gradient-to-br from-accent-600 to-accent-950 rounded-2xl p-8 md:p-12 lg:p-16 shadow-[0_20px_60px_rgba(0,0,0,0.15)] text-center';
const headingClass = embedded
  ? 'text-lg md:text-xl font-bold mb-3'
  : 'text-2xl md:text-3xl lg:text-4xl font-bold mb-4 md:mb-6';
const headingStyle = embedded ? 'color: white; margin: 0;' : 'color: white;';
const buttonsClass = embedded
  ? 'flex flex-col sm:flex-row gap-3 mt-4 justify-center'
  : 'flex flex-col md:flex-row gap-4 justify-center items-center';
const secondaryButtonClass = embedded
  ? 'inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-white border-2 border-accent-200 hover:bg-accent-200/10 rounded-lg transition-colors w-full sm:w-auto no-underline'
  : 'inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white border-2 border-accent-200 hover:bg-accent-200/10 rounded-lg transition-colors w-full md:w-auto';
const primaryButtonClass = embedded
  ? 'inline-flex items-center justify-center px-5 py-2.5 text-sm font-medium text-white bg-accent-600 hover:bg-accent-700 border-2 border-accent-600 rounded-lg transition-colors w-full sm:w-auto no-underline'
  : 'inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-accent-600 hover:bg-accent-700 border-2 border-accent-600 rounded-lg transition-colors w-full md:w-auto';
---

<Wrapper class={wrapperClass}>
  <div class={containerClass}>
    <div class={cardClass} style="color: white;">
      <Heading class={headingClass} style={headingStyle}>
        Want to learn more?
      </Heading>
      <div class={buttonsClass}>
        <a
          href="https://cal.glasskube.com/team/gk/demo"
          class={secondaryButtonClass}
          target="_blank"
          rel="noopener noreferrer">
          Talk to an Expert
        </a>
        <a href="/white-paper/building-blocks/" class={primaryButtonClass}>
          Download White Paper
        </a>
      </div>
    </div>
  </div>
</Wrapper>
