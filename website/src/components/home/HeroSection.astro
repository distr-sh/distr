---
import DemoButton from '~/components/buttons/DemoButton.astro';
import SignupButton from '~/components/buttons/SignupButton.astro';
import HeroCarousel from './HeroCarousel.astro';
import {images} from '~/assets/index';
---

<header
  class="relative overflow-hidden bg-gradient-to-br from-accent-950 via-accent-700 to-accent-600 py-8 md:py-16"
  style="color: white;">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="text-center max-w-5xl mx-auto">
      <h1
        class="text-3xl md:text-5xl lg:text-6xl font-bold mb-6 md:mb-8 leading-tight"
        style="color: white;">
        Ship self-managed software like SaaS
      </h1>
      <p
        class="mx-auto mb-8 max-w-3xl text-lg md:text-xl leading-relaxed text-white/90">
        Distr gives your customers a SaaS-like path to install, update, and
        support software in their own cloud, VPC, or air-gapped environment, so
        your team can ship self-managed offerings without operating overhead.
      </p>
    </div>

    <div class="flex flex-col items-center gap-4 mb-8">
      <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
        <DemoButton class="w-full md:w-auto" />
        <SignupButton class="w-full md:w-auto" />
      </div>

      <div class="mt-6 md:mt-10 text-center">
        <h4 class="text-base md:text-lg mb-2 opacity-90" style="color: white;">
          Backed by
        </h4>
        <a
          href="https://www.ycombinator.com/companies/glasskube"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block transition-opacity hover:opacity-80">
          <img
            src={images.yc.badge.src}
            alt="Glasskube backed by Y Combinator"
            class="h-10 md:h-12 mx-auto"
          />
        </a>
      </div>
    </div>

    <div class="mt-8 md:mt-16 mb-8 md:mb-16">
      <HeroCarousel />
    </div>
  </div>
</header>
