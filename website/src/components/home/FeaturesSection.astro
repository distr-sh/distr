---
import {Icon} from 'astro-icon/components';

const features = [
  {
    title: 'Close enterprise deals',
    icon: 'lucide:handshake',
    description:
      'Give security-conscious customers a clear path to run your software in environments they control, including VPC, GovCloud, and air-gapped environments.',
  },
  {
    title: 'Ship updates in minutes, not days',
    icon: 'lucide:refresh-cw',
    description:
      'Replace manual upgrade calls and one-off runbooks with repeatable update workflows for every self-managed customer.',
  },
  {
    title: 'Turn self-managed into a scalable product motion',
    icon: 'lucide:repeat-2',
    description:
      'Use the same core release motion across cloud and self-managed deployments, so engineers do not have to treat every customer environment as a one-off project.',
  },
];
---

<section class="py-8 md:py-16 lg:py-24 bg-white dark:bg-gray-900">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="text-center mb-8 md:mb-16 max-w-4xl mx-auto">
      <h2 class="text-2xl md:text-3xl lg:text-4xl font-bold leading-tight">
        Self-managed delivery should help you win bigger customers, not consume
        your roadmap.
      </h2>
      <p class="mt-4 text-base md:text-lg text-gray-600 dark:text-gray-300">
        Distr packages the operational work around self-managed deployments into
        a platform your sales, success, support, and engineering teams can rely
        on.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mt-8 md:mt-16">
      {
        features.map(feature => (
          <div class="text-center px-4 md:px-6">
            <div class="relative inline-flex items-center justify-center w-20 h-20 md:w-24 md:h-24 mb-6 rounded-full bg-gradient-to-br from-[#00b5eb] to-[#63c5e3] p-1">
              <div class="w-full h-full rounded-full bg-white dark:bg-gray-900 flex items-center justify-center">
                <Icon name={feature.icon} class="text-4xl" />
              </div>
            </div>
            <h3 class="text-xl md:text-2xl font-bold mb-3 md:mb-4">
              {feature.title}
            </h3>
            <p class="text-base md:text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
              {feature.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
