---
import {getCollection} from 'astro:content';
import {marked} from 'marked';
import Layout from '~/layouts/StarlightLayout.astro';
import SignUpCta from '~/components/cta/standalone/SignUpCta.astro';
import TestimonialsSection from '~/components/home/TestimonialsSection.astro';
import FAQ from '~/components/common/FAQ.astro';
import type {StarlightPageProps} from '@astrojs/starlight/components/StarlightPage.astro';
import '~/styles/cra.css';

const guides = (await getCollection('cra')).sort(
  (a, b) => a.data.order - b.data.order,
);

const title = 'Cyber Resilience Act Compliance for Software Vendors';
const description =
  'Everything software vendors with self-hosted, on-prem, and air-gapped customers need to know about the EU Cyber Resilience Act: who is affected, deadlines, secure update distribution, and step-by-step compliance guidance.';

const now = new Date();

const milestoneData = [
  {
    date: new Date('2024-12-10T00:00:00Z'),
    dateLabel: 'Dec 10, 2024',
    label: 'CRA enters into force',
    detail: 'Regulation (EU) 2024/2847 becomes law.',
    action: 'Start your scope memo and classify your products.',
  },
  {
    date: new Date('2026-06-11T00:00:00Z'),
    dateLabel: 'Jun 11, 2026',
    label: 'Assessment bodies ready',
    detail: 'Conformity assessment body provisions apply.',
    action: 'Plan third-party assessments for Class I and II products.',
  },
  {
    date: new Date('2026-09-11T00:00:00Z'),
    dateLabel: 'Sep 11, 2026',
    label: 'Reporting obligations start',
    detail:
      'Actively exploited vulnerabilities: 24h early warning to your CSIRT and ENISA. Applies to products already on the market.',
    action:
      'Have the reporting runbook and per-customer version tracking ready.',
  },
  {
    date: new Date('2027-12-11T00:00:00Z'),
    dateLabel: 'Dec 11, 2027',
    label: 'Full compliance required',
    detail:
      'Essential requirements, SBOM, technical documentation, conformity assessment, and CE marking.',
    action: 'Complete the technical file and secure update distribution.',
  },
];

// Derive each milestone's state from the build date instead of hardcoding it,
// so the markers stay consistent with the "you are here" progress bar.
const firstUpcoming = milestoneData.findIndex(m => m.date > now);
const milestones = milestoneData.map((m, i) => ({
  ...m,
  state:
    firstUpcoming === -1 || i < firstUpcoming
      ? 'past'
      : i === firstUpcoming
        ? 'next'
        : 'future',
}));

const euCraUrl =
  'https://digital-strategy.ec.europa.eu/en/policies/cyber-resilience-act';
const craLegalTextUrl =
  'https://eur-lex.europa.eu/legal-content/EN/TXT/?uri=CELEX%3A32024R2847';

const faqs = [
  {
    question: 'Does the Cyber Resilience Act apply to non-EU companies?',
    answer:
      'Yes. The CRA applies to any product with digital elements placed on the EU market, regardless of where the manufacturer is headquartered. A US vendor selling software to EU customers is covered exactly like an EU vendor.',
  },
  {
    question: 'Does the CRA apply to SaaS?',
    answer:
      'Software offered purely as a service is not placed on the market as a product and is out of CRA scope, though NIS2 or DORA may apply depending on sector and size. Self-hosted editions, on-prem agents, desktop clients, and installers are products in scope.',
  },
  {
    question: 'Is open-source software exempt?',
    answer:
      'Non-commercial open-source software is out of scope. Monetized editions carry full manufacturer obligations. Open-core companies typically act as manufacturer for the enterprise edition and as open-source software steward for the community edition, a light regime without fines.',
  },
  {
    question: 'What happens if we do nothing?',
    answer:
      'From September 11, 2026 you are subject to 24-hour reporting duties for actively exploited vulnerabilities. From December 11, 2027, non-compliant products cannot be newly placed on the EU market. Fines reach EUR 15 million or 2.5% of worldwide annual turnover, and market surveillance authorities can force withdrawals and recalls.',
  },
];

// Short definitions of the CRA terms from the glossary, appended to the FAQ.
const craGlossarySlugs = [
  'cyber-resilience-act',
  'product-with-digital-elements',
  'remote-data-processing-solution',
  'open-source-software-steward',
  'cra-support-period',
  'security-update-vs-functionality-update',
  'coordinated-vulnerability-disclosure',
];
const glossaryEntries = await getCollection('glossary');
const glossaryFaqs = craGlossarySlugs.flatMap(slug => {
  const entry = glossaryEntries.find(e => e.data.slug === slug);
  if (!entry?.data.term || !entry.data.shortDefinition) return [];
  return [
    {
      question: `What does "${entry.data.term}" mean?`,
      answer: `${marked.parseInline(entry.data.shortDefinition)} <a href="/glossary/${slug}/">Read the full glossary entry</a>.`,
    },
  ];
});
const allFaqs = [...faqs, ...glossaryFaqs];

const reportingDeadline = new Date('2026-09-11T00:00:00Z');
const daysToReporting = Math.max(
  0,
  Math.ceil((reportingDeadline.getTime() - now.getTime()) / 86400000),
);

// "You are here" position on the timeline: milestones sit at the centers of a
// 4-column grid (12.5%, 37.5%, 62.5%, 87.5%). Interpolate today's position
// between the surrounding milestone dates.
const centers = [12.5, 37.5, 62.5, 87.5];
let progressPct = centers[0];
for (let i = 0; i < milestoneData.length - 1; i++) {
  if (now >= milestoneData[i].date) {
    const span =
      milestoneData[i + 1].date.getTime() - milestoneData[i].date.getTime();
    const frac = Math.min(
      1,
      (now.getTime() - milestoneData[i].date.getTime()) / span,
    );
    progressPct = centers[i] + frac * (centers[i + 1] - centers[i]);
  }
}
progressPct = Math.round(progressPct * 10) / 10;

const canonicalUrl = new URL('/cyber-resilience-act/', Astro.site).toString();
const ldJson = (obj: unknown) => JSON.stringify(obj).replace(/</g, '\\u003c');

const head: StarlightPageProps['frontmatter']['head'] = [
  {
    tag: 'script',
    attrs: {type: 'application/ld+json'},
    content: ldJson({
      '@context': 'https://schema.org',
      '@type': 'CollectionPage',
      name: title,
      description,
      url: canonicalUrl,
      hasPart: guides.map(g => ({
        '@type': 'Article',
        headline: g.data.title,
        url: new URL(
          `/cyber-resilience-act/${g.data.slug}/`,
          Astro.site,
        ).toString(),
      })),
    }),
  },
];
---

<Layout title={title} description={description} head={head}>
  {/* Hero */}
  <div class="relative overflow-hidden py-16 sm:py-24">
    <div class="relative mx-auto max-w-4xl px-6 sm:px-8 lg:px-10 text-center">
      <p
        class="text-sm font-semibold uppercase tracking-wide text-blue-600 dark:text-blue-400 mb-4">
        EU Cyber Resilience Act
      </p>
      <h1
        class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl mb-6">
        CRA compliance for software vendors with self-hosted customers
      </h1>
      <p
        class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 max-w-3xl mx-auto mb-8">
        If your customers run your software themselves, the Cyber Resilience Act
        applies to you. Practical guides on scope, deadlines, secure update
        distribution, and what to do first, written without legalese and with
        the sources cited.
      </p>
      {
        daysToReporting > 0 && (
          <p class="text-sm text-gray-600 dark:text-gray-400">
            <span class="font-semibold text-blue-600 dark:text-blue-400">
              {daysToReporting} days
            </span>{' '}
            until the 24-hour vulnerability reporting obligation starts on
            September 11, 2026.
          </p>
        )
      }
    </div>
  </div>

  {/* What is the CRA */}
  <div class="py-12 sm:py-16">
    <div class="mx-auto max-w-3xl px-6 sm:px-8 lg:px-10">
      <h2
        class="text-2xl font-bold text-gray-900 dark:text-white mb-6 text-center">
        What is the Cyber Resilience Act?
      </h2>
      <div
        class="text-gray-600 dark:text-gray-400 leading-relaxed space-y-4 text-base sm:text-lg">
        <p>
          The Cyber Resilience Act is <a
            href={craLegalTextUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 dark:text-blue-400 hover:underline"
            >Regulation (EU) 2024/2847</a
          >, which sets mandatory cybersecurity requirements for products with
          digital elements placed on the EU market. It entered into force on
          December 10, 2024 and applies in three stages: provisions on
          conformity assessment bodies apply since June 11, 2026, reporting
          obligations for actively exploited vulnerabilities start on September
          11, 2026, and the full set of requirements, including CE marking,
          technical documentation, SBOM, and conformity assessment, applies from
          December 11, 2027.
        </p>
        <p>
          The regulation covers both hardware and software and applies
          regardless of where the manufacturer is established; what matters is
          whether the product is placed on the EU market. Manufacturers must
          build products securely, handle vulnerabilities throughout a defined
          support period, distribute security updates through a secure
          mechanism, and report actively exploited vulnerabilities to their
          CSIRT and ENISA. Non-compliance with the essential requirements can be
          fined with up to EUR 15 million or 2.5% of worldwide annual turnover,
          whichever is higher.
        </p>
        <p class="text-sm">
          See also the{' '}
          <a
            href="/glossary/cyber-resilience-act/"
            class="text-blue-600 dark:text-blue-400 hover:underline"
            >Cyber Resilience Act glossary entry</a
          >{' '}
          and the{' '}
          <a
            href={euCraUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-blue-600 dark:text-blue-400 hover:underline"
            >official European Commission page on the Cyber Resilience Act</a
          >.
        </p>
      </div>
    </div>
  </div>

  {/* Horizontal timeline */}
  <div class="py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 lg:px-10">
      <h2
        class="text-2xl font-bold text-gray-900 dark:text-white mb-12 text-center">
        How much time do you have?
      </h2>

      <div class="relative md:pt-10">
        {/* Connector line (desktop) */}
        <div
          class="hidden md:block absolute top-[3.5rem] left-[12.5%] right-[12.5%] h-0.5 bg-gray-200 dark:bg-slate-700">
        </div>
        <div
          class="hidden md:block absolute top-[3.5rem] left-[12.5%] h-0.5 bg-blue-600 dark:bg-blue-500"
          style={`width: ${progressPct - 12.5}%`}>
        </div>
        {/* "You are here": dot exactly on the line at today's position */}
        <div
          class="hidden md:block absolute z-10 w-3 h-3 rounded-full bg-blue-600 dark:bg-blue-500 ring-4 ring-white dark:ring-slate-900"
          style={`left: ${progressPct}%; top: calc(3.5rem - 0.3125rem); transform: translateX(-50%)`}>
        </div>
        <div
          class="hidden md:flex absolute z-10 flex-col items-center"
          style={`left: ${progressPct}%; top: 0; transform: translateX(-50%)`}>
          <span
            class="whitespace-nowrap text-xs font-semibold text-blue-600 dark:text-blue-400">
            you are here
          </span>
          <svg
            class="w-3 h-3 mt-0.5 text-blue-600 dark:text-blue-400"
            fill="currentColor"
            viewBox="0 0 12 12">
            <path d="M6 12L0 4h12z"></path>
          </svg>
        </div>

        <div class="grid gap-10 md:gap-6 md:grid-cols-4">
          {
            milestones.map(m => (
              <div class="relative flex md:flex-col items-start md:items-center gap-4 md:gap-0 md:text-center">
                {/* Marker */}
                <div class="flex-shrink-0 relative z-10 md:mb-5">
                  <div
                    class:list={[
                      'w-8 h-8 rounded-full border-4 flex items-center justify-center',
                      m.state === 'past' &&
                        'bg-blue-600 border-blue-600 dark:bg-blue-500 dark:border-blue-500',
                      m.state === 'next' &&
                        'bg-white dark:bg-slate-900 border-blue-600 dark:border-blue-500 animate-pulse',
                      m.state === 'future' &&
                        'bg-white dark:bg-slate-900 border-gray-300 dark:border-slate-600',
                    ]}>
                    {m.state === 'past' && (
                      <svg
                        class="w-4 h-4 text-white"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        viewBox="0 0 24 24">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                    )}
                  </div>
                </div>

                {/* Content */}
                <div>
                  <span
                    class:list={[
                      'inline-block rounded-full px-3 py-1 text-xs font-bold mb-2',
                      m.state === 'next'
                        ? 'bg-blue-600 text-white dark:bg-blue-500'
                        : 'bg-gray-100 text-gray-700 dark:bg-slate-800 dark:text-gray-300',
                    ]}>
                    {m.dateLabel}
                  </span>
                  <h3 class="text-base font-bold text-gray-900 dark:text-white mb-1">
                    {m.label}
                  </h3>
                  <p class="text-sm text-gray-600 dark:text-gray-400 mb-2">
                    {m.detail}
                  </p>
                  <p class="text-xs text-blue-700 dark:text-blue-400">
                    <span class="font-semibold">Action required:</span>{' '}
                    {m.action}
                  </p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  {/* Guides */}
  <div
    class="bg-gradient-to-br from-accent-400 to-accent-600 dark:from-accent-600 dark:to-accent-950 py-12 sm:py-16">
    <div class="mx-auto max-w-5xl px-6 sm:px-8 lg:px-10">
      <h2 class="text-2xl font-bold text-white mb-2 text-center">
        Cyber Resilience Act Content Hub
      </h2>
      <p class="text-white opacity-90 text-center mb-10 max-w-2xl mx-auto">
        Written for vendors, checked against the regulation text, and kept
        current as the Commission guidance evolves.
      </p>
      <div class="grid gap-6 md:grid-cols-2">
        {
          guides.map(g => (
            <a
              href={`/cyber-resilience-act/${g.data.slug}/`}
              class="block p-6 bg-white/10 hover:bg-white/20 rounded-xl border border-white/20 hover:border-white/40 transition-colors no-underline text-white">
              <h3 class="text-xl font-semibold text-white mb-2">
                {g.data.title}
              </h3>
              <p class="text-sm text-white opacity-90">{g.data.teaser}</p>
            </a>
          ))
        }
      </div>
    </div>
  </div>

  <FAQ faqs={allFaqs} bgClass="bg-gray-50 dark:bg-gray-800" />
  <SignUpCta bgClass="bg-[var(--sl-color-bg)]" />
  <TestimonialsSection />
</Layout>
