---
import {getCollection, render} from 'astro:content';
import {marked} from 'marked';
import Layout from '~/layouts/StarlightLayout.astro';
import SignUpCta from '~/components/cta/standalone/SignUpCta.astro';
import TestimonialsSection from '~/components/home/TestimonialsSection.astro';
import FAQ from '~/components/common/FAQ.astro';
import type {CraGuideConfig} from '~/content.config';
import type {StarlightPageProps} from '@astrojs/starlight/components/StarlightPage.astro';

export async function getStaticPaths() {
  const guides = await getCollection('cra');
  return guides.map(guide => ({
    params: {slug: guide.data.slug},
    props: {guide},
  }));
}

const {guide} = Astro.props;
const {Content} = await render(guide);
const {title, description, slug, publishDate, lastUpdated, faq} =
  guide.data as CraGuideConfig;

const faqRendered =
  faq?.map(({question, answer}) => ({
    question,
    answer: marked.parseInline(answer) as string,
  })) ?? [];

const canonicalUrl = new URL(
  `/cyber-resilience-act/${slug}/`,
  Astro.site,
).toString();
const hubUrl = new URL('/cyber-resilience-act/', Astro.site).toString();
const ldJson = (obj: unknown) => JSON.stringify(obj).replace(/</g, '\\u003c');

const head: StarlightPageProps['frontmatter']['head'] = [
  {
    tag: 'script',
    attrs: {type: 'application/ld+json'},
    content: ldJson({
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      url: canonicalUrl,
      datePublished: publishDate.toISOString().split('T')[0],
      dateModified: lastUpdated.toISOString().split('T')[0],
      isPartOf: {
        '@type': 'WebPage',
        name: 'Cyber Resilience Act Compliance for Software Vendors',
        url: hubUrl,
      },
      author: {
        '@type': 'Organization',
        name: 'Distr',
        url: 'https://distr.sh',
      },
    }),
  },
  {
    tag: 'script',
    attrs: {type: 'application/ld+json'},
    content: ldJson({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Cyber Resilience Act',
          item: hubUrl,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: title,
          item: canonicalUrl,
        },
      ],
    }),
  },
];

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
  }).format(new Date(date));
---

<style>
  .guide-content :global(h2) {
    font-size: 1.5rem;
    line-height: 2rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-top: 3rem;
    margin-bottom: 1rem;
  }
  .guide-content :global(h3) {
    font-size: 1.25rem;
    line-height: 1.75rem;
    font-weight: 700;
    letter-spacing: -0.025em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .guide-content :global(p) {
    line-height: 1.75;
  }
  .guide-content :global(a:not([class])) {
    color: var(--sl-color-text-accent);
    text-decoration: none;
  }
  .guide-content :global(a:not([class]):hover) {
    text-decoration: underline;
  }
  .guide-content :global(table) {
    margin-top: 2rem;
    margin-bottom: 2rem;
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9375rem;
    background-color: #ffffff;
  }
  .guide-content :global(th) {
    background-color: #f3f4f6;
    font-weight: 600;
    text-align: left;
  }
  .guide-content :global(th),
  .guide-content :global(td) {
    border: 1px solid #e5e7eb;
    padding: 0.625rem 0.875rem;
    vertical-align: top;
  }
  .guide-content :global(tbody tr:nth-child(even)) {
    background-color: #f9fafb;
  }
  /* Match pricing table dark surfaces — Starlight gray tokens wash out */
  :root[data-theme='dark'] .guide-content :global(table) {
    background-color: #111827; /* gray-900 */
  }
  :root[data-theme='dark'] .guide-content :global(th) {
    background-color: #030712; /* gray-950 */
  }
  :root[data-theme='dark'] .guide-content :global(th),
  :root[data-theme='dark'] .guide-content :global(td) {
    border-color: #374151; /* gray-700 */
  }
  :root[data-theme='dark'] .guide-content :global(tbody tr:nth-child(even)) {
    background-color: #1f2937; /* gray-800 */
  }
  /* Mermaid diagrams render with light node fills, so give them a light
     card in both modes instead of floating white boxes on dark background */
  .guide-content :global(svg) {
    max-width: 100%;
    height: auto;
    margin: 2rem auto;
    display: block;
    background: #ffffff;
    border: 1px solid var(--sl-color-gray-5, #e5e7eb);
    border-radius: 0.5rem;
    padding: 1.25rem;
    box-sizing: border-box;
  }
  /* rehype-mermaid measures text with different font metrics than the
     browser renders, which clips node labels. Letting the foreignObject
     overflow and tightening the label line-height fixes the clipping. */
  .guide-content :global(svg foreignObject) {
    overflow: visible;
  }
  .guide-content :global(svg .nodeLabel),
  .guide-content :global(svg .edgeLabel) {
    line-height: 1.15;
  }
</style>

<Layout title={title} description={description} head={head}>
  <section class="py-8 sm:py-12 mx-auto">
    <article class="max-w-3xl mx-auto px-6 sm:px-8">
      <!-- Back to hub button -->
      <div class="mb-8 text-center">
        <a
          href="/cyber-resilience-act/"
          class="inline-flex items-center text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 transition-colors no-underline">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
          Cyber Resilience Act
        </a>
      </div>

      <header class="mb-12 text-center">
        <!-- Title -->
        <h1
          class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight text-gray-900 dark:text-white mb-3 leading-tight">
          {title}
        </h1>

        <!-- Description -->
        <p
          class="text-lg sm:text-xl text-gray-600 dark:text-gray-400 sm:mb-16 mb-8 leading-relaxed max-w-3xl mx-auto mt-8">
          {description}
        </p>

        <!-- Meta information row -->
        <div
          class="flex flex-col sm:flex-row sm:justify-between sm:items-center text-sm text-gray-600 dark:text-gray-400 pb-8 border-b border-gray-200 dark:border-gray-800 max-w-3xl mx-auto">
          <span class="flex items-center gap-1">
            <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            Last verified: {formatDate(lastUpdated)}
          </span>
          <time
            datetime={publishDate.toISOString()}
            class="mt-2 sm:mt-0 self-start">
            {formatDate(publishDate)}
          </time>
        </div>
      </header>

      <!-- Article content: sl-markdown-content applies Starlight's typography
           (headings, tables, lists), which is loaded globally and consistent
           with the docs. The site does not ship the Tailwind typography
           plugin, so prose-* classes have no effect here. -->
      <div class="sl-markdown-content guide-content">
        <Content />
      </div>

      <footer
        class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800 text-center">
        <a
          href="/cyber-resilience-act/"
          class="inline-flex items-center text-sm text-blue-600 dark:text-blue-400 hover:text-blue-700 dark:hover:text-blue-300 no-underline">
          <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path></svg>
          All Cyber Resilience Act guides
        </a>
      </footer>
    </article>
  </section>
  {faqRendered.length > 0 && <FAQ faqs={faqRendered} />}
  <SignUpCta bgClass="bg-[var(--sl-color-bg)]" />
  <TestimonialsSection />
</Layout>
