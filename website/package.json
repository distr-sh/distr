{
  "name": "distr.sh",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "copy-changelog": "cat src/content/docs/_changelog-header.md > src/content/docs/changelog.md && tail -n +2 ../CHANGELOG.md >> src/content/docs/changelog.md",
    "predev": "pnpm copy-changelog",
    "prestart": "pnpm copy-changelog",
    "prebuild": "pnpm copy-changelog",
    "precheck": "pnpm copy-changelog",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "screenshots:homepage": "node scripts/capture-homepage-screenshots.mjs",
    "lint": "prettier --check .",
    "format": "prettier --write --list-different ."
  },
  "dependencies": {
    "@astrojs/markdown-remark": "7.2.1",
    "@astrojs/mdx": "7.0.3",
    "@astrojs/preact": "6.0.1",
    "@astrojs/sitemap": "3.7.3",
    "@astrojs/starlight": "0.41.4",
    "@astrojs/starlight-tailwind": "5.0.0",
    "@iconify-json/lucide": "^1.2.105",
    "@tailwindcss/vite": "^4.2.4",
    "astro": "7.1.3",
    "astro-icon": "^1.1.5",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "github-buttons": "^2.32.0",
    "marked": "^18.0.2",
    "mermaid": "^11.15.0",
    "node-html-parser": "^8.0.0",
    "playwright": "^1.59.1",
    "preact": "^10.29.1",
    "rehype-external-links": "^3.0.0",
    "rehype-mermaid": "^3.0.0",
    "sharp": "^0.35.0",
    "starlight-links-validator": "^0.25.0",
    "starlight-sidebar-topics": "^0.8.0",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "baseline-browser-mapping": "^2.10.24",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.16.0",
  "engines": {
    "node": "26.x"
  }
}
